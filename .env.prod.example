# Copiar a .env.prod en el servidor y completar. NUNCA commitear .env.prod con secretos reales.
NODE_ENV=production
PORT=3000

POSTGRES_USER=eduplay
POSTGRES_PASSWORD=GENERAR_PASSWORD_FUERTE_AQUI
POSTGRES_DB=eduplay
DATABASE_URL=postgresql://eduplay:GENERAR_PASSWORD_FUERTE_AQUI@db:5432/eduplay?schema=public

JWT_SECRET=GENERAR_MINIMO_32_CARACTERES_ALEATORIOS
BCRYPT_ROUNDS=12
TRUST_PROXY=true

# Dominios reales de la app web / Expo web y panel admin (NUNCA usar *)
CORS_ALLOWED_ORIGINS=https://eduplay.app,https://admin.eduplay.app

# Monitoreo (crear proyecto en https://sentry.io)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Rate limits más estrictos en producción
LOGIN_REGISTER_RATE_LIMIT_MAX=5
LOGIN_REGISTER_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=50
API_RATE_LIMIT_WINDOW_MS=900000
PROD_API_RATE_LIMIT_MAX=50
PROD_API_RATE_LIMIT_WINDOW_MS=900000

AUTO_SEED_DEMO=false
DOCKERHUB_IMAGE=tu-usuario/eduplay-api:latest
API_HOST_PORT=3800

# Cloudinary / IAP (opcional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
