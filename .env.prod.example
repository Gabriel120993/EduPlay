DOCKERHUB_IMAGE=GABRIELBERNABE/eduplay-api:latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=eduplay

JWT_SECRET=cambia-este-jwt-secret-por-uno-muy-largo-y-seguro
BCRYPT_ROUNDS=12
TRUST_PROXY=true
API_HOST_PORT=3800

# IMPORTANTE:
# - true solo para primer arranque si queres cargar demo padre/hijo.
# - luego dejar en false para no reseedear.
AUTO_SEED_DEMO=false

# Opcionales
APPLE_IAP_SHARED_SECRET=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=eduplay
CLOUDINARY_MODERATION=
