// EduPlay — esquema PostgreSQL completo (IDs UUID).
// Conserva modelos usados por la API actual y extiende gamificación, contenido, social y operaciones.

generator client {
  provider = "prisma-client-js"
  output   = "../.prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Cuentas: tutor (Parent) y menores (User)
// ---------------------------------------------------------------------------

model Parent {
  id              String                    @id @default(uuid())
  email           String                    @unique
  password        String
  isPremium       Boolean                   @default(false)
  premiumUntil    DateTime?
  expoPushToken   String?                   @db.Text
  children        User[]
  childSettings   ParentSettings[]
  iapTransactions IapProcessedTransaction[]
  userBlocks      ParentUserBlock[]
  familyEvents    ParentFamilyEvent[]
  createdAt       DateTime                  @default(now())
}

model IapProcessedTransaction {
  id         String   @id @default(uuid())
  platform   String
  externalId String
  parentId   String
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  productId  String
  createdAt  DateTime @default(now())

  @@unique([platform, externalId])
}

model User {
  id               String     @id @default(uuid())
  username         String     @unique
  realName         String
  type             UserType   @default(minor)
  status           UserStatus @default(active)
  passwordHash     String?
  age              Int
  avatarUrl        String?
  profileImageUrl  String?

  /// Gamificación base (legacy + mural de perfil).
  level       Int @default(1)
  experience  Int @default(0)
  /// Monedas (pistas, tienda suave); nombre histórico `quizCoins` en producto.
  quizCoins   Int @default(0)
  /// Racha genérica de actividad diaria (app).
  activityStreakDays    Int       @default(0)
  lastActivityStreakUtc DateTime? @db.Date

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id])

  parentSettings ParentSettings? @relation("ChildParentSettings")
  screenTime     ScreenTime?

  posts            Post[]
  achievements     UserAchievement[]
  gameResults      GameResult[]
  reactions        Reaction[]
  interests        UserInterest[]
  userMissions     UserMission[]
  xpGainLedgers    XpGainLedger[]
  analyticsEvents  AnalyticsEvent[]
  dailyChallengeBonuses DailyChallengeBonus[]
  gamifiedChallenges    UserGamifiedChallenge[]
  thematicMissionProgress UserThematicMissionProgress[]
  thematicMissionVotes    ThematicMissionVote[]

  streaks               UserStreak[]
  gamificationSnapshots UserGamificationSnapshot?
  notifications         AppNotification[]
  miniGameSessions      MiniGameSession[]
  studyGroupMemberships StudyGroupMember[]
  studyGroupMessages    StudyGroupMessage[]
  liveEventAttendees    LiveEventAttendee[]

  onboardingCompletedAt DateTime?
  onboardingFirstAction   String?

  expoPushToken String? @db.Text

  notificationsEnabled        Boolean @default(true)
  notificationSoundsEnabled   Boolean @default(true)
  achievementsPublicOnProfile Boolean @default(true)

  chatSent     ChatMessage[] @relation("ChatSent")
  chatReceived ChatMessage[] @relation("ChatReceived")
  chatsAsUser1 Chat[]        @relation("ChatThreadUser1")
  chatsAsUser2 Chat[]        @relation("ChatThreadUser2")
  messagesSent     Message[] @relation("DmMessageSender")
  messagesReceived Message[] @relation("DmMessageReceiver")

  reportsFiled   ContentReport[] @relation("UserReportsFiled")
  reportsAgainst ContentReport[] @relation("UserReportsAgainst")

  parentBlocksAsChild   ParentUserBlock[] @relation("ParentBlockChild")
  parentBlockedAsTarget ParentUserBlock[] @relation("ParentBlockBlockedTarget")

  mediaUploads UserMediaUpload[]

  quizAreaSkills    UserQuizAreaSkill[]
  quizFlashcards    UserQuizFlashcard[]
  quizDailyProgress QuizDailyProgress[]
  quizStreakState   UserQuizStreak?

  parentAccountApprovedAt DateTime?

  parentProfile ParentProfile?
  minorProfile  MinorProfile?
  minorDependents MinorProfile[] @relation("MinorProfileParent")
  parentChildRelationsAsParent ParentChildRelation[] @relation("ParentChildRelationParent")
  parentChildRelationsAsChild  ParentChildRelation[] @relation("ParentChildRelationChild")
  activityApprovalsAsParent    ActivityApproval[]    @relation("ActivityApprovalParent")
  activityApprovalsAsMinor     ActivityApproval[]    @relation("ActivityApprovalMinor")

  quizAttempts QuizAttempt[]
  quizSessions QuizSession[]

  /** Uso de pantalla por día civil (UTC); el límite sigue en ParentSettings.dailyScreenTimeLimit (0 = ilimitado). */
  dailyTimeUsages DailyTimeUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([parentId])
  @@index([type, status])
}

model DailyTimeUsage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  usedSeconds Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

/// Snapshot opcional para auditoría / analytics de gamificación.
model UserGamificationSnapshot {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXpEarned    Int      @default(0)
  totalCoinsSpent  Int      @default(0)
  lastLevelUpAt    DateTime?
  updatedAt        DateTime @updatedAt
}

/// Rachas tipadas (quiz diario, login, misión, etc.).
model UserStreak {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          StreakKind
  currentCount  Int        @default(0)
  bestCount     Int        @default(0)
  lastEventDate DateTime?  @db.Date
  updatedAt     DateTime   @updatedAt

  @@unique([userId, kind])
  @@index([userId, kind])
}

model UserMediaUpload {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url               String    @db.Text
  resourceType      String    @db.VarChar(16)
  publicId          String    @unique @db.VarChar(512)
  moderationFlagged Boolean   @default(false)
  moderationNote    String?   @db.VarChar(500)
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  post Post?

  @@index([userId, createdAt])
}

model ParentUserBlock {
  id            String   @id @default(uuid())
  parentId      String
  parent        Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  childId       String
  child         User     @relation("ParentBlockChild", fields: [childId], references: [id], onDelete: Cascade)
  blockedUserId String
  blockedUser   User     @relation("ParentBlockBlockedTarget", fields: [blockedUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([childId, blockedUserId])
  @@index([parentId])
}

model ParentFamilyEvent {
  id         String   @id @default(uuid())
  parentId   String
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  kind       String   @db.VarChar(32)
  childId    String
  peerUserId String?
  title      String   @db.VarChar(200)
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([parentId, createdAt])
}

// ---------------------------------------------------------------------------
// XP y economía virtual
// ---------------------------------------------------------------------------

model XpGainLedger {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  source    XpGainSource
  metadata  Json?
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

enum XpGainSource {
  GAME_RESULT
  MISSION
  ACHIEVEMENT
  CHALLENGE
  QUIZ
  MINI_GAME
  LIVE_EVENT
  CONTENT
}

// ---------------------------------------------------------------------------
// Misiones diarias (plantillas) + instancias por día
// ---------------------------------------------------------------------------

model Mission {
  id           String           @id @default(uuid())
  title        String
  description  String
  category     ContentCategory?
  targetValue  Int
  type         MissionType
  userMissions UserMission[]
}

model UserMission {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId       String
  mission         Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  progress        Int       @default(0)
  completed       Boolean   @default(false)
  rewardXpGranted Int?
  date            DateTime  @db.Date

  @@unique([userId, missionId, date])
  @@index([userId, date])
}

model DailyChallengeBonus {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  bonusXp   Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

enum ChallengeBucket {
  DAILY
  WEEKLY
  SPECIAL
}

model UserGamifiedChallenge {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bucket          ChallengeBucket
  periodKey       String          @db.VarChar(64)
  challengeSlug   String          @db.VarChar(64)
  title           String
  description     String          @db.Text
  target          Int
  progress        Int             @default(0)
  completed       Boolean         @default(false)
  completedAt     DateTime?
  rewardsGranted  Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, bucket, periodKey, challengeSlug])
  @@index([userId, bucket, periodKey])
}

model UserThematicMissionProgress {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionSlug      String    @db.VarChar(128)
  thematicMissionId String?
  thematicMission  ThematicMission? @relation(fields: [thematicMissionId], references: [id], onDelete: SetNull)
  currentStepIndex Int       @default(0)
  completed        Boolean   @default(false)
  bestScore        Int?
  attemptCount     Int       @default(1)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, missionSlug])
  @@index([userId])
  @@index([thematicMissionId])
}

/// Catálogo persistido (opcional; puede sincronizarse con seed/código).
model ThematicMission {
  id          String   @id @default(uuid())
  slug        String   @unique @db.VarChar(128)
  title       String
  theme       String
  narrative   String   @db.Text
  reward      String
  stepCount   Int
  seasonMonth String?  @db.VarChar(7)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progressRows UserThematicMissionProgress[]
}

model ThematicMissionVote {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionSlug String   @db.VarChar(128)
  createdAt   DateTime @default(now())

  @@unique([userId, missionSlug])
  @@index([missionSlug])
}

// ---------------------------------------------------------------------------
// Contenido educativo: categorías → materias → temas → ítems
// ---------------------------------------------------------------------------

model EducationalCategory {
  id        String   @id @default(uuid())
  slug      String   @unique @db.VarChar(64)
  name      String
  icon      String?  @db.VarChar(64)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  subjects EducationalSubject[]

  @@index([sortOrder])
}

model EducationalSubject {
  id         String   @id @default(uuid())
  categoryId String
  category   EducationalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug       String   @db.VarChar(80)
  name       String
  sortOrder  Int      @default(0)

  topics EducationalTopic[]

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model EducationalTopic {
  id        String   @id @default(uuid())
  subjectId String
  subject   EducationalSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  slug      String   @db.VarChar(96)
  name      String
  summary   String?  @db.Text
  sortOrder Int      @default(0)

  contents EducationalContent[]
  quizzes  Quiz[]

  @@unique([subjectId, slug])
  @@index([subjectId, sortOrder])
}

/// Recurso multimedia curado (imagen, audio, video, ícono) con variantes de tamaño y metadatos de licencia.
model EducationalAsset {
  id        String @id @default(uuid())
  type      String @db.VarChar(16)
  category  String @db.VarChar(64)
  name      String @db.VarChar(120)
  title     String
  description String? @db.Text

  urlSmall  String @db.Text
  urlMedium String @db.Text
  urlLarge  String @db.Text

  source    String  @db.VarChar(32)
  sourceUrl String? @db.Text
  license   String  @db.VarChar(32)

  tags String[] @default([])

  usedInQuizzes Int @default(0)
  usedInContent Int @default(0)

  createdAt DateTime @default(now())

  visualQuestions VisualQuestion[]
  heroForContents EducationalContent[]
  quizImageQuestions QuizQuestion[] @relation("QuizQuestionImageAsset")

  @@unique([category, name])
  @@index([category])
  @@index([tags], type: Gin)
}

model EducationalContent {
  id          String            @id @default(uuid())
  title       String
  description String
  content     String            @db.Text
  /// Tipo de recurso pedagógico.
  contentType EducationalContentType @default(READING)
  category    String
  difficulty  Difficulty
  imageUrl    String?
  /// Imagen principal curada (sustituye o refina `imageUrl` en API si está definida).
  heroImageAssetId String?
  heroImageAsset   EducationalAsset? @relation(fields: [heroImageAssetId], references: [id], onDelete: SetNull)
  topicId     String?
  topic       EducationalTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  /// Metadatos (duración video, materiales experimento, etc.).
  meta        Json?
  published   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt

  @@index([topicId])
  @@index([contentType, published])
  @@index([heroImageAssetId])
}

enum EducationalContentType {
  VIDEO
  READING
  EXPERIMENT
  INTERACTIVE
  WORKSHEET
  AUDIO
}

// ---------------------------------------------------------------------------
// Quizzes agrupados + preguntas
// ---------------------------------------------------------------------------

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String   @default("") @db.Text
  topicId     String?
  topic       EducationalTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  /// Legacy / feed: alineado con ContentCategory cuando no hay topic.
  legacyCategory ContentCategory?
  difficulty  Difficulty @default(MEDIUM)
  questionCount Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]
  sessions  QuizSession[]

  @@index([topicId])
  @@index([published])
}

model QuizQuestion {
  id         String     @id @default(uuid())
  quizId     String?
  quiz       Quiz?      @relation(fields: [quizId], references: [id], onDelete: SetNull)
  question   String
  options    Json
  correct    Int
  category   String
  difficulty Difficulty
  quizLevel  Int        @default(2)
  knowledgeArea QuizKnowledgeArea @default(mathematics)
  topicSlug  String     @default("general") @db.VarChar(120)
  questionType QuizQuestionType @default(MULTIPLE_CHOICE)
  explanation String    @default("") @db.Text
  hintText   String?    @db.Text
  hintCost   Int        @default(5)
  readingPassage String? @db.Text
  orderTapSequence Json?
  /// Imagen de la pregunta (p. ej. bandera); `options` / `correct` siguen siendo texto + índice.
  imageAssetId String?
  imageAsset   EducationalAsset? @relation("QuizQuestionImageAsset", fields: [imageAssetId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now())

  flashcards UserQuizFlashcard[]

  @@index([quizId])
  @@index([category])
  @@index([imageAssetId])
}

/// Intento / sesión de quiz (puntuación agregada).
model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score       Int
  maxScore    Int
  correctCount Int
  durationMs  Int?
  finishedAt  DateTime @default(now())

  @@index([userId, finishedAt])
  @@index([quizId])
}

/// Sesión REST de quiz (respuestas parciales antes de finalizar).
model QuizSession {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId     String
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers    Json      @default("[]")
  finished   Boolean   @default(false)
  score      Int       @default(0)
  maxScore   Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([userId, startedAt])
  @@index([quizId])
}

model UserQuizAreaSkill {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  area          QuizKnowledgeArea
  adaptiveLevel Int              @default(2)
  lastCorrect   Int              @default(0)
  lastWrong     Int              @default(0)
  updatedAt     DateTime         @updatedAt

  @@unique([userId, area])
  @@index([userId])
}

model UserQuizFlashcard {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  easeFactor   Float        @default(2.5)
  intervalDays Float        @default(0)
  repetitions  Int          @default(0)
  nextReviewAt DateTime
  createdAt    DateTime     @default(now())

  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
}

model QuizDailyProgress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day        DateTime @db.Date
  bestScore  Int      @default(0)
  attempts   Int      @default(0)

  @@unique([userId, day])
  @@index([userId, day])
}

model UserQuizStreak {
  userId               String    @id
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  streakDays           Int       @default(0)
  lastQualifyingDayUtc DateTime? @db.Date
}

model VisualQuestion {
  id         String     @id @default(uuid())
  imageUrl   String
  imageAssetId String?
  imageAsset   EducationalAsset? @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)
  question   String
  options    Json
  correct    Int
  category   String
  difficulty Difficulty
  createdAt  DateTime   @default(now())

  @@index([category])
  @@index([imageAssetId])
}

enum QuizKnowledgeArea {
  mathematics
  natural_sciences
  social_sciences
  language
  art_culture
  logic_thinking
  emotions_values
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ORDER
}

// ---------------------------------------------------------------------------
// Minijuegos (catálogo) + sesiones de juego
// ---------------------------------------------------------------------------

model MiniGame {
  id          String          @id @default(uuid())
  slug        String          @unique @db.VarChar(64)
  name        String
  description String          @default("") @db.Text
  category    ContentCategory
  difficulty  Difficulty      @default(MEDIUM)
  /// Configuración (niveles, assets, reglas).
  config      Json            @default("{}")
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sessions MiniGameSession[]

  @@index([isActive, sortOrder])
}

model MiniGameSession {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  miniGameId String
  miniGame   MiniGame @relation(fields: [miniGameId], references: [id], onDelete: Cascade)
  score      Int
  durationMs Int?
  levelIndex Int?
  metadata   Json?
  startedAt  DateTime @default(now())
  endedAt    DateTime?

  @@index([userId, endedAt])
  @@index([miniGameId])
}

/// Modelo legacy de juego (resultados); mantener por compatibilidad con posts / feeds.
model Game {
  id         String          @id @default(uuid())
  name       String
  category   ContentCategory
  difficulty String

  results GameResult[]
}

model GameResult {
  id     String @id @default(uuid())
  score  Int
  userId String
  user   User   @relation(fields: [userId], references: [id])
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])

  createdAt DateTime @default(now())

  activityPost Post?

  @@index([userId, createdAt])
  @@index([gameId])
}

// ---------------------------------------------------------------------------
// Social: amigos, grupos de estudio, chat 1:1 y grupal
// ---------------------------------------------------------------------------

model Friend {
  id                     String       @id @default(uuid())
  status                 FriendStatus
  requiresParentApproval Boolean      @default(true)
  parentApproved         Boolean      @default(false)
  userId                 String
  friendId               String
  createdAt              DateTime     @default(now())

  @@unique([userId, friendId])
  @@index([userId, createdAt])
  @@index([friendId])
}

model StudyGroup {
  id          String   @id @default(uuid())
  name        String
  description String   @default("") @db.Text
  ownerUserId String
  inviteCode  String?  @unique @db.VarChar(16)
  maxMembers  Int      @default(12)
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  StudyGroupMember[]
  messages StudyGroupMessage[]

  @@index([ownerUserId])
}

model StudyGroupMember {
  id       String         @id @default(uuid())
  groupId  String
  group    StudyGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     StudyGroupRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model StudyGroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  moderated Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
  @@index([senderId])
}

model ChatMessage {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  body        String   @db.Text
  blocked     Boolean  @default(false)
  blockReason String?  @db.VarChar(200)
  auditPlain  String?  @db.Text
  moderationFlagged Boolean @default(false)
  createdAt   DateTime @default(now())

  sender    User @relation("ChatSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ChatReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  contentReports ContentReport[]

  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@index([senderId, recipientId, createdAt])
}

model Chat {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  user1 User @relation("ChatThreadUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("ChatThreadUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  isFlagged  Boolean  @default(false)

  sender   User @relation("DmMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("DmMessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

// ---------------------------------------------------------------------------
// Feed, reacciones, logros y coleccionables
// ---------------------------------------------------------------------------

model Post {
  id                     String   @id @default(uuid())
  content                String?
  imageUrl               String?
  videoUrl                 String?  @db.Text
  mediaModerationFlagged Boolean  @default(false)
  mediaModerationNote    String?  @db.VarChar(500)
  mediaUploadId          String?  @unique
  mediaUpload            UserMediaUpload? @relation(fields: [mediaUploadId], references: [id], onDelete: SetNull)
  category               ContentCategory?
  type                   PostType
  visibility             Visibility
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  gameResultId           String?  @unique
  gameResult             GameResult? @relation(fields: [gameResultId], references: [id], onDelete: SetNull)
  userAchievementId      String?  @unique
  userAchievement        UserAchievement? @relation(fields: [userAchievementId], references: [id], onDelete: SetNull)
  parentModerationVisibleAt   DateTime?
  parentModerationVisibleById String?   @db.VarChar(36)

  reactions Reaction[]
  contentReports ContentReport[]

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  postId    String
  post      Post         @relation(fields: [postId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model Achievement {
  id            String                @id @default(uuid())
  title         String
  description   String
  iconUrl       String?
  category      ContentCategory
  badgeColor    String                @default("#6366f1")
  badgeIcon     String                @default("badge")
  rarity        AchievementRarity     @default(COMMON)
  systemKind    AchievementSystemKind @default(PROGRESS)
  hidden        Boolean               @default(false)
  collectionKey String?               @db.VarChar(64)
  slug          String?               @unique @db.VarChar(96)
  sortOrder     Int                   @default(0)

  users UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  obtainedAt    DateTime    @default(now())
  activityPost  Post?

  @@unique([userId, achievementId])
  @@index([achievementId])
}

model UserInterest {
  id       String          @id @default(uuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ContentCategory
  score    Int             @default(0)

  @@unique([userId, category])
}

// ---------------------------------------------------------------------------
// Moderación y reportes
// ---------------------------------------------------------------------------

model ContentReport {
  id               String              @id @default(uuid())
  targetType       ContentReportTarget
  reason           String?             @db.VarChar(500)
  status           ContentReportStatus @default(OPEN)
  resolutionNote   String?             @db.VarChar(500)
  priority         Int                 @default(0)
  reporterUserId   String
  reporter         User                @relation("UserReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  postId           String?
  post             Post?               @relation(fields: [postId], references: [id], onDelete: SetNull)
  reportedUserId   String?
  reportedUser     User?               @relation("UserReportsAgainst", fields: [reportedUserId], references: [id], onDelete: SetNull)
  chatMessageId    String?
  chatMessage      ChatMessage?        @relation(fields: [chatMessageId], references: [id], onDelete: SetNull)
  reviewedByParentId String?          @db.VarChar(36)
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([priority, status])
}

model ModerationLog {
  id       String  @id @default(uuid())
  flagged  Boolean
  reason   String?
  reviewed Boolean @default(false)
  postId   String
}

// ---------------------------------------------------------------------------
// Eventos en vivo
// ---------------------------------------------------------------------------

model LiveEvent {
  id          String          @id @default(uuid())
  title       String
  description String          @default("") @db.Text
  startsAt    DateTime
  endsAt      DateTime
  streamUrl   String?         @db.Text
  status      LiveEventStatus @default(SCHEDULED)
  hostLabel   String?
  coverUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  attendees LiveEventAttendee[]

  @@index([startsAt, endsAt])
  @@index([status])
}

model LiveEventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  event     LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  watchMs   Int?

  @@unique([eventId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Notificaciones in-app
// ---------------------------------------------------------------------------

model AppNotification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationKind
  title     String
  body      String              @db.Text
  data      Json                @default("{}")
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Perfiles, aprobaciones, analítica
// ---------------------------------------------------------------------------

model ParentSettings {
  id                           String             @id @default(uuid())
  parentId                     String
  parent                       Parent             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  childId                      String             @unique
  child                        User               @relation("ChildParentSettings", fields: [childId], references: [id], onDelete: Cascade)
  dailyScreenTimeLimit         Int                @default(120)
  allowPosting                 Boolean            @default(true)
  allowFriends                 Boolean            @default(true)
  chatEnabled                  Boolean            @default(true)
  parentChatSupervisionEnabled Boolean            @default(true)
  notifyParentNewContact       Boolean            @default(true)
  notifyParentSuspiciousChat   Boolean            @default(true)
  contentFilterLevel           ContentFilterLevel @default(MEDIUM)

  @@index([parentId])
}

model ScreenTime {
  id                String   @id @default(uuid())
  dailyLimitMinutes Int      @map("dailyLimitMinutes")
  usedTodaySeconds  Int      @default(0) @map("usedTodaySeconds")
  lastReset         DateTime
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventName String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventName, createdAt])
  @@index([createdAt])
}

model ParentProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationStatus VerificationStatus @default(pending)
  verificationMethod VerificationMethod
  subscriptionTier   SubscriptionTier   @default(free)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([verificationStatus])
  @@index([subscriptionTier])
}

model MinorProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId            String
  parent              User     @relation("MinorProfileParent", fields: [parentId], references: [id], onDelete: Restrict)
  age                 Int
  gradeLevel          String?
  school              String?
  interests           Json     @default("[]")
  dailyTimeLimit      Int
  contentRestrictions Json     @default("{}")
  canMakePurchases    Boolean  @default(false)
  canAddFriends       Boolean  @default(true)
  canPostContent      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([parentId])
  @@index([age, gradeLevel])
}

model ParentChildRelation {
  id                  String                    @id @default(uuid())
  parentId            String
  parent              User                      @relation("ParentChildRelationParent", fields: [parentId], references: [id], onDelete: Cascade)
  childId             String
  child               User                      @relation("ParentChildRelationChild", fields: [childId], references: [id], onDelete: Cascade)
  status              ParentChildRelationStatus @default(pending)
  approvalRequiredFor Json                      @default("[]")
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([parentId, childId])
  @@index([parentId, status])
  @@index([childId, status])
}

model ActivityApproval {
  id           String                 @id @default(uuid())
  minorId      String
  minor        User                   @relation("ActivityApprovalMinor", fields: [minorId], references: [id], onDelete: Cascade)
  parentId     String
  parent       User                   @relation("ActivityApprovalParent", fields: [parentId], references: [id], onDelete: Cascade)
  activityType ActivityType
  activityData Json                   @default("{}")
  status       ActivityApprovalStatus @default(pending)
  requestedAt  DateTime               @default(now())
  respondedAt  DateTime?

  @@index([minorId, status, requestedAt])
  @@index([parentId, status, requestedAt])
  @@index([activityType, status])
}

