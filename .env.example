# Copiar a .env y ajustar. JWT_SECRET: mínimo 32 caracteres (p. ej. openssl rand -base64 48).
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://eduplay:eduplay2024@localhost:5432/eduplay
JWT_SECRET=cambiar-por-secreto-largo-aleatorio-minimo-32-caracteres
BCRYPT_ROUNDS=12
TRUST_PROXY=false
# CORS: orígenes separados por comas. En desarrollo: Expo web, Metro, API. En producción: solo dominios reales (evitar *).
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3000,http://localhost:8081
