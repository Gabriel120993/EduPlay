# Servidor
PORT=3000
NODE_ENV=development

# PostgreSQL (cadena de conexión para Prisma)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eduplay?schema=public"

# Auth JWT — obligatorio; mínimo 32 caracteres aleatorios (HS256, expira a los 7 días)
# Generar: openssl rand -base64 48
JWT_SECRET="la-pagina-eduplay-es-lo-mejor-que-existe"

# Contraseñas bcrypt (10–14; por defecto 12)
BCRYPT_ROUNDS=12

# Rate limiting (opcional)
# Login/registro tutor: por defecto 100 req / 15 min por IP
# LOGIN_REGISTER_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_REGISTER_RATE_LIMIT_MAX=100
# Otras rutas sensibles (login hijo, IAP, …)
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=25
# API_RATE_LIMIT_WINDOW_MS=60000
# API_RATE_LIMIT_MAX=200
# Por cuenta JWT (menor): ventana y máximo adicional a la IP
# API_CHILD_USER_RATE_LIMIT_WINDOW_MS=60000
# API_CHILD_USER_RATE_LIMIT_MAX=280
# Por cuenta JWT (tutor)
# API_PARENT_USER_RATE_LIMIT_WINDOW_MS=60000
# API_PARENT_USER_RATE_LIMIT_MAX=900
# Solicitudes de amistad salientes (por menor)
# FRIEND_REQUEST_BURST_WINDOW_MS=60000
# FRIEND_REQUEST_BURST_MAX=5
# FRIEND_REQUEST_WINDOW_MS=900000
# FRIEND_REQUEST_MAX=14
# Máximo de filas Friend nuevas (mismo remitente) en 1 h
# FRIEND_REQUEST_DB_MAX_PER_HOUR=40
# Denuncias por menor en 24 h
# CONTENT_REPORT_USER_MAX_PER_24H=24
# Alerta si N menores distintos denuncian al mismo usuario (USER) en 24 h
# USER_REPORT_DISTINCT_REPORTERS_ALERT=4

# Tras proxy inverso (nginx, etc.): true para `req.ip` y rate limit correctos
TRUST_PROXY=false

# IAP — validación en servidor (App Store verifyReceipt)
APPLE_IAP_SHARED_SECRET=""

# IAP — Google Play (JSON de cuenta de servicio con acceso a Android Publisher)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
# Opcional: debe coincidir con applicationId de la app Android
GOOGLE_PLAY_PACKAGE_NAME=""

# Cloudinary — subida de imágenes/videos (POST /api/media/upload)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Carpeta raíz en Cloudinary (default: eduplay)
# CLOUDINARY_UPLOAD_FOLDER="eduplay"
# Moderación en subida si el add-on está activo en Cloudinary (p. ej. aws_rek, perception_point)
# CLOUDINARY_MODERATION=""
