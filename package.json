{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "eduplay-api",
  "version": "1.0.0",
  "description": "API backend EduPlay (Express, Prisma, PostgreSQL)",
  "private": true,
  "scripts": {
    "sounds:generate": "node scripts/generate-eduplay-sounds.mjs",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test:prepare": "npm run prisma:generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/app.smoke.test.ts tests/auth.integration.test.ts tests/thematicMissions.catalog.test.ts tests/role.middleware.test.ts",
    "test:db": "vitest run --config vitest.db.config.ts",
    "qa:audit": "node scripts/qa-audit.mjs",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "db:seed": "prisma db seed",
    "db:seed:safe": "cross-env SEED_SKIP_DB_CLEAR=1 prisma db seed",
    "db:seed:educational": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/seed-educational.ts",
    "db:seed:play-games": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/seed-play-games.ts",
    "db:seed:library": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/seed-content-library.ts",
    "db:seed:images": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/seed-images.ts",
    "db:repair:wikimedia-widths": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/rewrite-wikimedia-widths.ts",
    "db:repair:asset-urls": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/repair-broken-asset-urls.ts",
    "db:prefetch:images": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/prefetch-asset-images.ts",
    "db:sync:visual-imageurls": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/sync-visual-question-imageurls.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:repair-checksums": "node scripts/prisma-repair-checksums.mjs && prisma db execute --file scripts/_repair_checksums.sql --schema prisma/schema.prisma",
    "verify": "node scripts/verify-installation.mjs",
    "check-env": "node scripts/check-env.mjs",
    "verify:prod": "node scripts/verify-prod.mjs",
    "shortcut": "node scripts/run-shortcut.cjs",
    "shortcut:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-shortcut.ps1",
    "shortcut:unix": "bash scripts/create-shortcut.sh",
    "shortcut:mac": "bash scripts/create-shortcut-mac.sh",
    "shortcut:linux": "bash scripts/create-shortcut-linux.sh"
  },
  "prisma": {
    "seed": "npx ts-node --project prisma/tsconfig.seed.json -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^9.5.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "prisma": "^6.0.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@eslint/js": "^9.21.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.1.4"
  }
}
